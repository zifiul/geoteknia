  provinceSlug String?             @map("province_slug") /// `provincia`
  leadType     LeadType?           @map("lead_type")
  source       LeadSource?         /// origen orgánico/SEM/directo
  pageUrl      String?             @map("page_url")
  sessionId    String?             @map("session_id")
  gaClientId   String?             @map("ga_client_id")
  formStep     Int?                @map("form_step") /// RNF-DATA
  value        Decimal?            @db.Decimal(12, 2) /// valor_estimado
  occurredAt   DateTime            @default(now()) @map("occurred_at")

  @@index([eventName])
  @@index([occurredAt])
  @@index([leadId])
  @@index([serviceSlug, provinceSlug])
  @@map("conversion_events")
}

/// Estados configurables del pipeline comercial (GTK-12 / RF-18)
model ProjectState {
  id          String                @id @default(uuid()) @db.Uuid
  name        String
  slug        String                @unique
  order       Int
  isInitial   Boolean               @map("is_initial")
  isWon       Boolean               @map("is_won")
  isLost      Boolean               @map("is_lost")
  isTerminal  Boolean               @map("is_terminal")
  projects    Project[]
  historyTo   ProjectStateHistory[] @relation("ToState")
  historyFrom ProjectStateHistory[] @relation("FromState")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  deletedAt   DateTime?             @map("deleted_at")
  createdById String?               @map("created_by_id") @db.Uuid
  updatedById String?               @map("updated_by_id") @db.Uuid

  @@index([order])
  @@map("project_states")
}

/// Ficha viva del pipeline, creada desde un lead (GTK-12 / RF-18)
model Project {
  id                   String                @id @default(uuid()) @db.Uuid
  leadId               String                @unique @map("lead_id") @db.Uuid
  lead                 Lead                  @relation(fields: [leadId], references: [id], onDelete: Restrict)
  contactId            String?               @map("contact_id") @db.Uuid
  contact              Contact?              @relation(fields: [contactId], references: [id], onDelete: SetNull)
  title                String
  stateId              String                @map("state_id") @db.Uuid
  state                ProjectState          @relation(fields: [stateId], references: [id], onDelete: Restrict)
  assignedTechnicianId String?               @map("assigned_technician_id") @db.Uuid
  assignedTechnician   User?                 @relation(fields: [assignedTechnicianId], references: [id], onDelete: SetNull)
  serviceId            String?               @map("service_id") @db.Uuid
  service              Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  provinceId           String?               @map("province_id") @db.Uuid
  province             Province?             @relation(fields: [provinceId], references: [id], onDelete: SetNull)
  workTypologyId       String?               @map("work_typology_id") @db.Uuid
  workTypology         WorkTypology?         @relation(fields: [workTypologyId], references: [id], onDelete: SetNull)
  estimatedValue       Decimal?              @map("estimated_value") @db.Decimal(12, 2)
  firstResponseAt      DateTime?             @map("first_response_at") /// control <48 h
  isQualified          Boolean               @default(false) @map("is_qualified")
  expedienteRef        String?               @map("expediente_ref")
  closedAt             DateTime?             @map("closed_at")
  stateHistory         ProjectStateHistory[]
  milestones           ProjectMilestone[]
  notes                ProjectNote[]
  documents            ProjectDocument[]
  sourceCaseStudies    CaseStudy[]           @relation("CaseStudySourceProject")
  createdAt            DateTime              @default(now()) @map("created_at")
  updatedAt            DateTime              @updatedAt @map("updated_at")
  deletedAt            DateTime?             @map("deleted_at")
  createdById          String?               @map("created_by_id") @db.Uuid
  updatedById          String?               @map("updated_by_id") @db.Uuid

  @@index([stateId])
  @@index([assignedTechnicianId])
  @@index([serviceId])
  @@index([provinceId])
  @@index([createdAt])
  @@index([isQualified])
  @@map("projects")
}

/// Append-only: sin updated_at/deleted_at
model ProjectStateHistory {
  id          String        @id @default(uuid()) @db.Uuid
  projectId   String        @map("project_id") @db.Uuid
  project     Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  fromStateId String?       @map("from_state_id") @db.Uuid
  fromState   ProjectState? @relation("FromState", fields: [fromStateId], references: [id], onDelete: SetNull)
  toStateId   String        @map("to_state_id") @db.Uuid
  toState     ProjectState  @relation("ToState", fields: [toStateId], references: [id], onDelete: Restrict)
  changedById String        @map("changed_by_id") @db.Uuid
  note        String?       @db.Text
  createdAt   DateTime      @default(now()) @map("created_at")

  @@index([projectId])
  @@index([toStateId])
  @@index([createdAt])
  @@map("project_state_history")
}

/// Hitos operativos del proyecto (GTK-12 / RF-18)
model ProjectMilestone {
  id          String           @id @default(uuid()) @db.Uuid
  projectId   String           @map("project_id") @db.Uuid
  project     Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title       String
  dueDate     DateTime?        @map("due_date") @db.Date
  completedAt DateTime?        @map("completed_at")
  status      MilestoneStatus?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdById String?          @map("created_by_id") @db.Uuid
  updatedById String?          @map("updated_by_id") @db.Uuid

  @@index([projectId])
  @@index([dueDate])
  @@map("project_milestones")
}

/// Notas internas del proyecto (GTK-12 / RF-18)
model ProjectNote {
  id          String    @id @default(uuid()) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  project     Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  authorId    String    @map("author_id") @db.Uuid
  body        String    @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid

  @@index([projectId])
  @@index([createdAt])
  @@map("project_notes")
}

/// Documentación privada del proyecto (GTK-12 / RF-18)
model ProjectDocument {
  id           String         @id @default(uuid()) @db.Uuid
  projectId    String         @map("project_id") @db.Uuid
  project      Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  mediaAssetId String?        @map("media_asset_id") @db.Uuid
  fileUrl      String?        @map("file_url")
  docType      ProjectDocType @map("doc_type")
  uploadedById String         @map("uploaded_by_id") @db.Uuid
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  deletedAt    DateTime?      @map("deleted_at")
  createdById  String?        @map("created_by_id") @db.Uuid
  updatedById  String?        @map("updated_by_id") @db.Uuid

  @@index([projectId])
  @@index([docType])
  @@map("project_documents")
}

/// Reglas configurables de la calculadora de alcance (GTK-15 / RF-Q1)
model CalculatorRule {
  id               String       @id @default(uuid()) @db.Uuid
  workTypologyId   String       @map("work_typology_id") @db.Uuid
  workTypology     WorkTypology @relation(fields: [workTypologyId], references: [id], onDelete: Cascade)
  minFloors        Int?         @map("min_floors")
  maxFloors        Int?         @map("max_floors")
  minAreaM2        Decimal?     @map("min_area_m2") @db.Decimal(10, 2)
  maxAreaM2        Decimal?     @map("max_area_m2") @db.Decimal(10, 2)
  boreholesFormula Json         @map("boreholes_formula") /// regla/fórmula
  depthEstimate    String?      @map("depth_estimate")
  recommendedTests String?      @map("recommended_tests") @db.Text
  cteReference     String?      @map("cte_reference") /// CTE DB-SE-C
  isActive         Boolean      @default(true) @map("is_active")
  // Bloque AUDIT
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid

  @@index([workTypologyId])
  @@index([isActive])
  @@index([workTypologyId, isActive])
  @@map("calculator_rules")
}

