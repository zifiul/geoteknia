// Fundación del esquema Prisma (GTK-6): enums transversales y convención de bloques.
// RBAC, usuarios, sesiones y auditoría (GTK-7).
// Activos multimedia y galería polimórfica (GTK-9).
// Catálogos maestros provincias y tipologías de obra (GTK-10).
// Configuración de organización y canales de contacto (GTK-11).
// Generación de contenido IA, tokens y revisiones editoriales (GTK-16).
// Servicios, geo-zonas, intersección servicio×zona y cobertura (GTK-18).
// Casos de estudio, equipo técnico y maquinaria (GTK-20).
// Acreditaciones y soporte de licitaciones (GTK-8).
// FAQs, lead magnets y reglas de calculadora (GTK-15).
// CRM ligero: contactos, leads, proyectos y pipeline (GTK-12).
// Los modelos restantes del dominio llegan en tickets DB siguientes según docs/technical/data-model.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Flujo editorial RF-20/21: transiciones permitidas borrador_ia -> en_revision -> aprobado -> publicado
/// (+ rechazado, despublicado). El enum no impone el orden; lo valida la lógica de /lib/.
enum WorkflowStatus {
  borrador_ia
  en_revision
  aprobado
  publicado
  rechazado
  despublicado
}

/// Tipo Schema.org para datos estructurados (Bloque SEO, RNF-SEO)
enum SchemaType {
  Service
  Article
  CreativeWork
  Person
  Organization
  FAQPage
  LocalBusiness
  BreadcrumbList
}

/// Modelo de Claude por defecto (RF-19 / RNF-IA). @map preserva el identificador real de la API.
enum AiModel {
  claude_sonnet_4_6 @map("claude-sonnet-4-6")
  claude_opus_4_8   @map("claude-opus-4-8")
}

/// RBAC del portal interno (RF-17)
enum RoleName {
  admin
  gestor
  editor
  tecnico
}

/// Acciones registradas en audit_logs (RF-17 / RNF-ADMIN)
enum AuditAction {
  publish
  approve
  reject
  delete
  login
  login_failed
  role_change
  ai_generate
  export
  state_change
  assign
  content_update
}

/// Tipo de activo multimedia (GTK-9 / RF-13)
enum AssetType {
  image
  pdf
  document
}

/// Tipo de página para la cual se generan prompts (GTK-16 / RF-19)
enum PromptPageType {
  service
  geo_zone
  service_zone
  case_study
  blog
  faq
  meta
}

/// Estado de una invocación a Claude (GTK-16 / RF-19)
enum AiGenerationStatus {
  success
  error
  partial
  retrying
}

/// Departamento de contacto para CTAs click-to-call/WhatsApp (GTK-11 / RF-08)
enum ContactDepartment {
  presupuestos
  direccion_tecnica
  licitaciones
}

/// Alcance de un grupo de FAQs (GTK-15 / RF-16)
enum FaqScope {
  general
  service
}

/// Tipo de credencial corporativa (GTK-8 / RF-12)
enum CredentialType {
  enac
  iso
  registro_ministerio
  clasificacion_contratista
  seguro_rc
  asociacion
}

/// Tipo de organismo contratante público (GTK-8 / RF-15)
enum OrganismType {
  ministerio
  confederacion
  puerto
  ayuntamiento
  otro
}

/// Clasificación de maquinaria geotécnica (GTK-20 / RF-07)
enum EquipmentType {
  sonda_rotacion
  sonda_percusion
  mixta
  ensayo_in_situ
  laboratorio
  vehiculo_especial
}

/// Tipo de conversión comercial (GTK-12 / RF-02)
enum LeadType {
  presupuesto
  licitacion
  recurso
  ubicacion
}

/// Canal de entrada del lead (GTK-12 / RF-08)
enum LeadChannel {
  formulario
  whatsapp
  tel
  ubicacion
  lead_magnet
}

/// Fuente de atribución del lead (GTK-12 / RF-15)
enum LeadSource {
  organico
  sem
  directo
  referral
}

/// Eventos de medición GTM/GA4 (GTK-14 / RF-10)
enum ConversionEventName {
  generate_lead
  click_tel
  click_whatsapp
  click_email
  send_location
  calculator_use
  resource_download
  scroll_depth
}

/// Estado de un hito del pipeline (GTK-12 / RF-18)
enum MilestoneStatus {
  pendiente
  cumplido
  retrasado
}

/// Tipo de documento privado del proyecto (GTK-12 / RF-18)
enum ProjectDocType {
  presupuesto
  informe
  contrato
  otro
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        RoleName         @unique
  label       String
  description String?
  users       User[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdById String?          @map("created_by_id") @db.Uuid
  updatedById String?          @map("updated_by_id") @db.Uuid

  @@map("roles")
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique /// p. ej. content.publish
  module      String /// projects | content | users | ai
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  deletedAt   DateTime?        @map("deleted_at")
  createdById String?          @map("created_by_id") @db.Uuid
  updatedById String?          @map("updated_by_id") @db.Uuid

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  roleId       String     @map("role_id") @db.Uuid
  permissionId String     @map("permission_id") @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

model User {
  id            String    @id @default(uuid()) @db.Uuid
  fullName      String    @map("full_name")
  email         String    @unique
  passwordHash  String    @map("password_hash") /// argon2/bcrypt (RNF-ADMIN)
  roleId        String    @map("role_id") @db.Uuid
  role          Role      @relation(fields: [roleId], references: [id], onDelete: Restrict)
  isActive      Boolean   @default(true) @map("is_active")
  twofaEnabled  Boolean   @default(false) @map("twofa_enabled")
  twofaSecret   String?   @map("twofa_secret") /// cifrado en reposo
  lastLoginAt   DateTime? @map("last_login_at")
  sessions          Session[]
  auditLogs         AuditLog[]
  teamMember        TeamMember?
  assignedProjects  Project[]
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")
  createdById   String?   @map("created_by_id") @db.Uuid
  updatedById   String?   @map("updated_by_id") @db.Uuid

  @@index([roleId])
  @@index([isActive])
  @@map("users")
}

/// Append-only operativo: sin updated_at/deleted_at (la revocación usa revoked_at)
model Session {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique @map("token_hash")
  ipAddress  String?   @map("ip_address")
  userAgent  String?   @map("user_agent")
  expiresAt  DateTime  @map("expires_at")
  revokedAt  DateTime? @map("revoked_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

/// Append-only inmutable: sin updated_at/deleted_at
model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  userId     String?     @map("user_id") @db.Uuid
  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  action     AuditAction
  entityType String?     @map("entity_type")
  entityId   String?     @map("entity_id") @db.Uuid
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")
  metadata   Json? /// diff/contexto de la acción
  createdAt  DateTime    @default(now()) @map("created_at")

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model MediaAsset {
  id                    String         @id @default(uuid()) @db.Uuid
  fileUrl               String         @map("file_url")
  assetType             AssetType      @map("asset_type")
  mimeType              String?        @map("mime_type")
  altText               String?        @map("alt_text")
  title                 String?
  width                 Int?
  height                Int?
  fileSizeKb            Int?           @map("file_size_kb")
  includeInImageSitemap Boolean        @default(true) @map("include_in_image_sitemap")
  contentMedia          ContentMedia[]
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  deletedAt             DateTime?      @map("deleted_at")
  createdById           String?        @map("created_by_id") @db.Uuid
  updatedById           String?        @map("updated_by_id") @db.Uuid

  @@index([assetType])
  @@index([includeInImageSitemap])
  @@map("media_assets")
}

/// Relación polimórfica: content_type + content_id apuntan a entidades de contenido
/// sin FK relacional dura (Prisma no soporta polimorfismo nativo). Integridad en /lib/.
model ContentMedia {
  id           String     @id @default(uuid()) @db.Uuid
  mediaAssetId String     @map("media_asset_id") @db.Uuid
  mediaAsset   MediaAsset @relation(fields: [mediaAssetId], references: [id], onDelete: Cascade)
  contentType  String     @map("content_type")
  contentId    String     @map("content_id") @db.Uuid
  order        Int        @default(0)

  @@index([contentType, contentId])
  @@map("content_media")
}

model Province {
  id                  String    @id @default(uuid()) @db.Uuid
  name                String
  slug                String    @unique
  ccaa                String /// comunidad autónoma
  ineCode             String?   @map("ine_code") /// código INE
  isOperational       Boolean   @default(false) @map("is_operational")
  defaultGeologyNotes String?   @map("default_geology_notes") @db.Text
  geoZones            GeoZone[]
  caseStudies         CaseStudy[]
  contacts            Contact[]
  leads               Lead[]
  projects            Project[]
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")
  deletedAt           DateTime? @map("deleted_at")
  createdById         String?   @map("created_by_id") @db.Uuid
  updatedById         String?   @map("updated_by_id") @db.Uuid

  @@index([isOperational])
  @@map("provinces")
}

model WorkTypology {
  id          String    @id @default(uuid()) @db.Uuid
  name        String
  slug        String    @unique
  description String?   @db.Text
  order       Int?
  caseStudies      CaseStudy[]
  calculatorRules  CalculatorRule[]
  leads            Lead[]
  projects         Project[]
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid

  @@map("work_typologies")
}

/// Singleton: se garantiza una sola fila por lógica de /lib/ (upsert por id fijo en seed).
model OrganizationProfile {
  id              String    @id @default(uuid()) @db.Uuid
  legalName       String    @map("legal_name")
  displayName     String    @map("display_name")
  napAddress      String    @map("nap_address")
  napPhone        String    @map("nap_phone")
  napEmail        String    @map("nap_email")
  gbpPlaceId      String?   @map("gbp_place_id")
  areaServed      Json      @map("area_served") /// provincias multivalor
  aggregateRating Decimal?  @map("aggregate_rating") @db.Decimal(3, 2)
  socialProfiles  Json?     @map("social_profiles")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")
  createdById     String?   @map("created_by_id") @db.Uuid
  updatedById     String?   @map("updated_by_id") @db.Uuid

  @@map("organization_profile")
}

model ContactChannel {
  id                       String            @id @default(uuid()) @db.Uuid
  department               ContactDepartment
  phone                    String?
  whatsappNumber           String?           @map("whatsapp_number")
  email                    String?
  prefilledMessageTemplate String?           @map("prefilled_message_template") @db.Text /// placeholders servicio/provincia
  isActive                 Boolean           @default(true) @map("is_active")
  createdAt                DateTime          @default(now()) @map("created_at")
  updatedAt                DateTime          @updatedAt @map("updated_at")
  deletedAt                DateTime?         @map("deleted_at")
  createdById              String?           @map("created_by_id") @db.Uuid
  updatedById              String?           @map("updated_by_id") @db.Uuid

  @@index([department])
  @@map("contact_channels")
}

/// Plantillas de prompts parametrizadas por tipo de página (GTK-16 / RF-19)
model PromptTemplate {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  pageType        PromptPageType @map("page_type")
  templateBody    String         @map("template_body") @db.Text /// con placeholders {{key}}
  inputSchema     Json           @map("input_schema") /// inputs requeridos del editor
  defaultModel    AiModel        @map("default_model")
  cacheablePrefix String?        @map("cacheable_prefix") @db.Text /// bloque estático para prompt caching
  version         Int
  isActive        Boolean        @default(true) @map("is_active")
  generations     AiGeneration[]
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")
  createdById     String?        @map("created_by_id") @db.Uuid
  updatedById     String?        @map("updated_by_id") @db.Uuid

  @@index([pageType])
  @@index([isActive])
  @@map("prompt_templates")
}

/// Registro de invocaciones a Claude con inputs, outputs, estado y reintentos (GTK-16 / RF-19)
model AiGeneration {
  id                  String             @id @default(uuid()) @db.Uuid
  promptTemplateId    String             @map("prompt_template_id") @db.Uuid
  promptTemplate      PromptTemplate     @relation(fields: [promptTemplateId], references: [id], onDelete: Restrict)
  targetContentType   String?            @map("target_content_type")
  targetContentId     String?            @map("target_content_id") @db.Uuid
  requestedById       String             @map("requested_by_id") @db.Uuid
  model               AiModel
  inputParams         Json               @map("input_params") /// valores del editor (sin PII)
  renderedPrompt      String?            @map("rendered_prompt") @db.Text
  outputText          String?            @map("output_text") @db.Text
  outputStructured    Json?              @map("output_structured") /// H1/H2-H3/meta/schema/links
  status              AiGenerationStatus
  errorMessage        String?            @map("error_message") @db.Text
  retryCount          Int                @default(0) @map("retry_count")
  latencyMs           Int?               @map("latency_ms")
  isSectionRegeneration Boolean          @default(false) @map("is_section_regeneration")
  parentGenerationId  String?            @map("parent_generation_id") @db.Uuid
  parentGeneration    AiGeneration?      @relation("GenerationLineage", fields: [parentGenerationId], references: [id], onDelete: SetNull)
  childGenerations    AiGeneration[]     @relation("GenerationLineage")
  tokenUsage          AiTokenUsage?
  contentRevisions    ContentRevision[]
  createdAt           DateTime           @default(now()) @map("created_at")
  deletedAt           DateTime?          @map("deleted_at")

  @@index([promptTemplateId])
  @@index([requestedById])
  @@index([model])
  @@index([status])
  @@index([createdAt])
  @@index([targetContentType, targetContentId])
  @@map("ai_generations")
}

/// Ledger append-only de tokens consumidos por generación (GTK-16 / RNF-IA)
model AiTokenUsage {
  id              String       @id @default(uuid()) @db.Uuid
  aiGenerationId  String       @unique @map("ai_generation_id") @db.Uuid
  aiGeneration    AiGeneration @relation(fields: [aiGenerationId], references: [id], onDelete: Cascade)
  model           AiModel
  inputTokens     Int          @map("input_tokens")
  outputTokens    Int          @map("output_tokens")
  cacheReadTokens Int?         @map("cache_read_tokens")
  cacheWriteTokens Int?        @map("cache_write_tokens")
  costEur         Decimal      @map("cost_eur") @db.Decimal(10, 4)
  billingPeriod   String       @map("billing_period") /// YYYY-MM
  createdAt       DateTime     @default(now()) @map("created_at")

  @@index([billingPeriod])
  @@index([model])
  @@index([createdAt])
  @@map("ai_token_usage")
}

/// Configuración de presupuesto mensual y alertas para IA (GTK-16 / RNF-IA)
model AiBudgetConfig {
  id               String    @id @default(uuid()) @db.Uuid
  billingPeriod    String?   @unique @map("billing_period") /// YYYY-MM; NULL = config global
  monthlyBudgetEur Decimal   @map("monthly_budget_eur") @db.Decimal(10, 2)
  alertThresholdPct Int      @map("alert_threshold_pct") /// p. ej. 80
  modelByPageType  Json?     @map("model_by_page_type") /// override de modelo por tipo
  notifyEmails     Json?     @map("notify_emails")
  isActive         Boolean   @default(true) @map("is_active")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  deletedAt        DateTime? @map("deleted_at")
  createdById      String?   @map("created_by_id") @db.Uuid
  updatedById      String?   @map("updated_by_id") @db.Uuid

  @@map("ai_budget_config")
}

/// Historial append-only de versiones editoriales de contenido publicable (GTK-16 / RF-20/21)
model ContentRevision {
  id               String         @id @default(uuid()) @db.Uuid
  contentType      String         @map("content_type")
  contentId        String         @map("content_id") @db.Uuid
  versionNumber    Int            @map("version_number")
  bodySnapshot     Json           @map("body_snapshot") /// cuerpo + estructura
  seoSnapshot      Json?          @map("seo_snapshot")
  workflowStatusAt WorkflowStatus @map("workflow_status_at")
  editorId         String         @map("editor_id") @db.Uuid
  changeSummary    String?        @map("change_summary")
  aiGenerationId   String?        @map("ai_generation_id") @db.Uuid
  aiGeneration     AiGeneration?  @relation(fields: [aiGenerationId], references: [id], onDelete: SetNull)
  createdAt        DateTime       @default(now()) @map("created_at")

  @@index([contentType, contentId, versionNumber])
  @@index([editorId])
  @@map("content_revisions")
}

/// Páginas pillar de servicios geotécnicos (GTK-18 / RF-01)
model Service {
  id              String    @id @default(uuid()) @db.Uuid
  name            String
  summary         String?   @db.Text
  body            String    @db.Text /// cuerpo H2/H3
  methodology     Json? /// pasos
  applicableNorms String?   @map("applicable_norms") @db.Text
  deliverables    Json? /// memoria, columnas litológicas...
  heroImageId     String?   @map("hero_image_id") @db.Uuid
  order           Int?
  isPillar        Boolean   @default(true) @map("is_pillar")
  // Bloque SEO
  slug            String    @unique
  metaTitle       String?   @map("meta_title") @db.VarChar(60)
  metaDescription String?   @map("meta_description") @db.VarChar(155)
  canonicalUrl    String?   @map("canonical_url")
  schemaType      SchemaType  @map("schema_type")
  noindex         Boolean   @default(false)
  ogImageId       String?   @map("og_image_id") @db.Uuid
  h1              String?
  // Bloque EDITORIAL
  workflowStatus     WorkflowStatus @default(borrador_ia) @map("workflow_status")
  isAiAssisted       Boolean        @default(false) @map("is_ai_assisted")
  authorId           String?        @map("author_id") @db.Uuid
  reviewedById       String?        @map("reviewed_by_id") @db.Uuid
  approvedById       String?        @map("approved_by_id") @db.Uuid
  approvedAt         DateTime?      @map("approved_at")
  publishedAt        DateTime?      @map("published_at")
  scheduledPublishAt DateTime?      @map("scheduled_publish_at")
  currentVersion     Int            @default(1) @map("current_version")
  // Bloque AUDIT
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  // Relaciones
  zoneCoverage      ServiceZoneCoverage[]
  serviceZonePages  ServiceZonePage[]
  caseStudies       CaseStudy[]
  machineryServices MachineryService[]
  blogPostServices  BlogPostService[]
  faqGroups         FaqGroup[]
  leadMagnets       LeadMagnet[]
  leads             Lead[]
  projects          Project[]

  @@index([workflowStatus])
  @@index([deletedAt])
  @@map("services")
}

/// Geo-landings por provincia (GTK-18 / RF-04)
model GeoZone {
  id              String   @id @default(uuid()) @db.Uuid
  provinceId      String   @map("province_id") @db.Uuid
  province        Province @relation(fields: [provinceId], references: [id], onDelete: Restrict)
  name            String
  localGeology    String   @map("local_geology") @db.Text
  operationalBase String?  @map("operational_base") @db.Text
  body            String   @db.Text
  wordCount       Int?     @map("word_count") /// control de thin content
  heroImageId     String?  @map("hero_image_id") @db.Uuid
  // Bloque SEO
  slug            String     @unique
  metaTitle       String?    @map("meta_title") @db.VarChar(60)
  metaDescription String?    @map("meta_description") @db.VarChar(155)
  canonicalUrl    String?    @map("canonical_url")
  schemaType      SchemaType @map("schema_type")
  noindex         Boolean    @default(false)
  ogImageId       String?    @map("og_image_id") @db.Uuid
  h1              String?
  // Bloque EDITORIAL
  workflowStatus     WorkflowStatus @default(borrador_ia) @map("workflow_status")
  isAiAssisted       Boolean        @default(false) @map("is_ai_assisted")
  authorId           String?        @map("author_id") @db.Uuid
  reviewedById       String?        @map("reviewed_by_id") @db.Uuid
  approvedById       String?        @map("approved_by_id") @db.Uuid
  approvedAt         DateTime?      @map("approved_at")
  publishedAt        DateTime?      @map("published_at")
  scheduledPublishAt DateTime?      @map("scheduled_publish_at")
  currentVersion     Int            @default(1) @map("current_version")
  // Bloque AUDIT
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")
  createdById String?   @map("created_by_id") @db.Uuid
  updatedById String?   @map("updated_by_id") @db.Uuid
  // Relaciones
  zoneCoverage     ServiceZoneCoverage[]
  serviceZonePages ServiceZonePage[]

  @@index([provinceId])
  @@index([workflowStatus])
  @@map("geo_zones")
}

/// Páginas de intersección servicio×zona (GTK-18 / RF-Q1 §8.3)
model ServiceZonePage {
  id            String  @id @default(uuid()) @db.Uuid
  serviceId     String  @map("service_id") @db.Uuid
  service       Service @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  zoneId        String  @map("zone_id") @db.Uuid
  zone          GeoZone @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  targetKeyword String? @map("target_keyword")
  body          String  @db.Text
  // Bloque SEO
  slug            String     @unique
  metaTitle       String?    @map("meta_title") @db.VarChar(60)
  metaDescription String?    @map("meta_description") @db.VarChar(155)
