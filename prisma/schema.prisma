// Fundación del esquema Prisma (GTK-6): enums transversales y convención de bloques.
// Los modelos del dominio llegan en tickets DB siguientes según docs/technical/data-model.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// Flujo editorial RF-20/21: transiciones permitidas borrador_ia -> en_revision -> aprobado -> publicado
/// (+ rechazado, despublicado). El enum no impone el orden; lo valida la lógica de /lib/.
enum WorkflowStatus {
  borrador_ia
  en_revision
  aprobado
  publicado
  rechazado
  despublicado
}

/// Tipo Schema.org para datos estructurados (Bloque SEO, RNF-SEO)
enum SchemaType {
  Service
  Article
  CreativeWork
  Person
  Organization
  FAQPage
  LocalBusiness
  BreadcrumbList
}

/// Modelo de Claude por defecto (RF-19 / RNF-IA). @map preserva el identificador real de la API.
enum AiModel {
  claude_sonnet_4_6 @map("claude-sonnet-4-6")
  claude_opus_4_8   @map("claude-opus-4-8")
}

