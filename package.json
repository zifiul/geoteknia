{
  "name": "geoteknia",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run tests/unit",
    "test:e2e": "playwright test",
    "db:seed": "prisma db seed",
    "security:install": "npm run security:install-tools",
    "security:install-tools": "npm run security:install-semgrep && npm run security:install-gitleaks",
    "security:install-semgrep": "powershell -ExecutionPolicy Bypass -File scripts/install-semgrep.ps1",
    "security:install-gitleaks": "powershell -ExecutionPolicy Bypass -File scripts/install-gitleaks.ps1",
    "security:sast": "powershell -ExecutionPolicy Bypass -File scripts/semgrep-scan.ps1",
    "security:sca": "powershell -ExecutionPolicy Bypass -File scripts/security-audit.ps1",
    "security:sca:json": "powershell -ExecutionPolicy Bypass -File scripts/security-audit.ps1 -Json",
    "security:secrets": "powershell -ExecutionPolicy Bypass -File scripts/gitleaks-detect.ps1",
    "security:dast": "powershell -ExecutionPolicy Bypass -File scripts/security-dast.ps1",
    "security:scan": "powershell -ExecutionPolicy Bypass -File scripts/security-scan.ps1",
    "security:semgrep": "npm run security:sast",
    "security:gitleaks": "npm run security:secrets"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^15.5.20",
    "prettier": "^3.9.5",
    "prisma": "^6.19.3",
    "tsx": "^4.23.1",
    "typescript": "5.9",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@prisma/client": "^6.19.3",
    "@react-email/components": "^1.0.12",
    "argon2": "^0.44.0",
    "next": "^15.5.20",
    "next-auth": "^5.0.0-beta.31",
    "otplib": "^13.4.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "resend": "^6.17.2",
    "server-only": "^0.0.1",
    "zod": "^4.4.3"
  },
  "prisma": {
    "seed": "npx tsx prisma/seed.ts"
  }
}
