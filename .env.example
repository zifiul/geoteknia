# Variables de entorno de Geoteknia — copia este fichero a .env y completa los valores.
# SEC-2: este fichero NUNCA debe contener valores reales.

# Cadena de conexión de PostgreSQL (Neon, región EU por RGPD) — pooler para runtime
DATABASE_URL="postgresql://usuario:password@host.eu-central-1.aws.neon.tech/geoteknia?sslmode=require"

# Conexión directa Neon (migraciones Prisma; sin pooler)
DIRECT_URL="postgresql://usuario:password@host.eu-central-1.aws.neon.tech/geoteknia?sslmode=require"

# Secreto de firma de sesiones de Auth.js v5 (generar con: openssl rand -base64 32)
NEXTAUTH_SECRET="cambiar-por-secreto-aleatorio"

# URL base de la aplicación para Auth.js
NEXTAUTH_URL="http://localhost:3000"

# Clave del SDK de Anthropic (Claude) — solo server-side, nunca en cliente
ANTHROPIC_API_KEY="sk-ant-..."

# Clave del servicio de email transaccional Resend
RESEND_API_KEY="re_..."

# Remitente verificado en Resend (formato: "Nombre <email@dominio.com>")
EMAIL_FROM="Geoteknia <noreply@geoteknia.com>"

# Dirección de respuesta para emails transaccionales
EMAIL_REPLY_TO="presupuestos@geoteknia.com"

# Clave secreta de Cloudflare Turnstile (validación anti-spam en servidor)
TURNSTILE_SECRET_KEY="0x..."

# Clave pública (site key) de Cloudflare Turnstile — visible en cliente por diseño
NEXT_PUBLIC_TURNSTILE_SITE_KEY="0x..."

# Entorno de ejecución: development | test | production
NODE_ENV="development"

# Duración de sesión del portal /admin (minutos, entero positivo)
SESSION_TTL_MINUTES="480"
